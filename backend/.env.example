# Copy this to .env and fill in your Supabase project values.
# Never commit .env to git.

# Supabase project URL (Settings → API → Project URL)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Supabase anon/public key (Settings → API → anon public)
SUPABASE_ANON_KEY=eyJ...

# Supabase service_role key — KEEP SECRET (Settings → API → service_role secret)
SUPABASE_SERVICE_KEY=eyJ...

# Direct PostgreSQL connection string for SQLAlchemy async
# Supabase: Settings → Database → Connection string → URI (mode: Session or Direct)
# Replace "postgresql://" with "postgresql+asyncpg://"
DATABASE_URL=postgresql+asyncpg://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
